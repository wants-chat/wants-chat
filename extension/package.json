{
  "name": "wants-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run copy-assets",
    "copy-assets": "cp manifest.json dist/ && cp -r public/icons dist/ && cp public/content-script.js dist/ && cp public/background.js dist/",
    "preview": "vite preview",
    "zip": "cd dist && zip -r ../wants-extension.zip .",
    "install:deps": "cd ../frontend && npm install && cd ../extension && npm install"
  },
  "dependencies": {
    "change-case": "^5.4.4",
    "chart.js": "^4.4.4",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.469.0",
    "pluralize": "^8.0.0",
    "qrcode.react": "^3.1.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.5.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^22.5.4",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "terser": "^5.46.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.3"
  }
}

{
  "manifest_version": 3,
  "name": "DevTools Pro - AI Code Review, Error Explainer & More",
  "version": "1.0.0",
  "description": "AI-powered developer tools: Code review, error explainer, regex builder, TypeScript generator, and more. Save hours daily.",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "clipboardRead"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://api.wants.chat/*"
  ]
}

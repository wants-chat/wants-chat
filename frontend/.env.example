# Life-OS Frontend Environment Variables Example
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_URL=http://localhost:3001
VITE_API_VERSION=v1

# Socket.io Configuration
VITE_SOCKET_URL=http://localhost:3001
VITE_SOCKET_PATH=/socket.io

# App Configuration
VITE_APP_NAME=Wants Chat
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
VITE_SITE_URL=http://localhost:5173

# Google Analytics 4 Configuration
# Get your ID from https://analytics.google.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Fluxez Analytics & Chatbot Configuration
# Lightweight, privacy-first analytics and chatbot
VITE_FLUXEZ_ANON_KEY=your_fluxez_anon_key_here
VITE_FLUXEZ_API_URL=https://api.fluxez.com

# Debug/Development
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

# Stripe Configuration (for billing UI)
# Get your publishable key at: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# External Services (add as needed)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
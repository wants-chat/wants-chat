# Database Configuration
#
# These defaults assume you are running Postgres natively on localhost
# (e.g. via `brew install postgresql`) and have manually created a
# database called `wantsdb` with a superuser called `postgres`.
#
# If you are running the full stack via `docker compose up`, you can
# leave these as-is — docker-compose.yml overrides DB_HOST/DB_USER/
# DB_PASSWORD/DB_NAME for the backend container, pointing it at the
# bundled Postgres service (user=wants, db=wants). See
# docs/self-hosting.md for details.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wantsdb
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
DB_POOL_MAX=20

# Tenant database (used by PlatformService / app-builder).
# In the standard OSS setup these point at the same Postgres as DB_*
# above. docker-compose.yml overrides these for the backend container,
# so you only need to set them when running the backend natively.
# PlatformService throws at startup if any of these are missing.
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_USER=postgres
TENANT_DB_PASSWORD=your_password_here
TENANT_DB_NAME=wantsdb

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:5180,http://localhost:3000

# API Configuration
API_PREFIX=api/v1

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5180

# =====================================================
# LLM CONFIGURATION (OpenRouter Unified Gateway)
# =====================================================
#
# We use OpenRouter as the unified gateway for ALL LLM providers.
# Benefits:
# - Single API key for 500+ models (OpenAI, Anthropic, Google, DeepSeek, etc.)
# - No $100 credit limit like direct Anthropic
# - Same pricing as direct API (5.5% fee on credit purchase only)
# - No rate limits for paid models
# - Easy model switching without code changes
#
# Get your OpenRouter API key at: https://openrouter.ai/keys
# =====================================================

# OpenRouter API Key (PRIMARY - required for multi-model support)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API Key (FALLBACK only - for OpenAI models if OpenRouter fails)
OPENAI_API_KEY=your_openai_api_key_here

# Default models (uses OpenRouter model IDs)
# Format: provider/model-name
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_CODE_MODEL=openai/gpt-4o-mini
OPENAI_REASONING_MODEL=openai/gpt-4o-mini
OPENAI_GENERATING_MODEL=openai/gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096

# Enable LLM Router for multi-provider support with billing
USE_LLM_ROUTER=true

# =====================================================
# AVAILABLE MODELS (via OpenRouter)
# =====================================================
# Default models are configured in code. To customize, set LLM_MODELS as JSON.
# Example (single line in .env):
# LLM_MODELS=[{"id":"openai/gpt-4o-mini","name":"GPT-4o Mini","description":"Fast and affordable","provider":"openai","inputPrice":150000,"outputPrice":600000,"contextWindow":128000,"maxOutput":16384,"tier":"standard","category":"chat","supportsVision":true,"supportsStreaming":true,"supportsJson":true,"isDefault":true,"isActive":true}]
#
# Available models by default:
# - openai/gpt-4o-mini (default) - $0.15/$0.60 per 1M tokens
# - openai/gpt-4o - $2.50/$10 per 1M tokens
# - anthropic/claude-haiku-4.5 - $1/$5 per 1M tokens
# - anthropic/claude-sonnet-4.5 - $3/$15 per 1M tokens
# - anthropic/claude-opus-4.5 - $5/$25 per 1M tokens
# - anthropic/claude-3.5-haiku - $0.80/$4 per 1M tokens
# - google/gemini-2.5-flash-lite - $0.10/$0.40 per 1M tokens
# - google/gemini-2.5-flash - $0.30/$2.50 per 1M tokens
# - google/gemini-2.5-pro - $1.25/$5 per 1M tokens
# - deepseek/deepseek-chat-v3 - $0.60/$1.70 per 1M tokens
# - deepseek/deepseek-r1 - $0.55/$2.19 per 1M tokens
# =====================================================

# Runware AI Configuration (for image/video generation)
RUNWARE_API_KEY=your_runware_api_key_here
RUNWARE_API_URL=https://api.runware.ai/v1
RUNWARE_MODEL_ID=rundiffusion:130@100
RUNWARE_FLUX_SCHNELL_MODEL_ID=runware:100@1
VIDEO_MODEL=bytedance:2@2

# OAuth Configuration (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# =====================================================
# GITHUB APP CONFIGURATION (for GitHub Sync feature)
# =====================================================
# Create a GitHub App at: https://github.com/settings/apps/new
#
# Settings for your GitHub App:
# - GitHub App name: "wants-chat" (or your preferred name)
# - Homepage URL: https://your-domain.com
# - Callback URL: https://your-api-domain.com/api/v1/app-github/oauth/callback
# - Webhook URL: https://your-api-domain.com/api/v1/app-github/webhook
# - Webhook secret: Generate a secure random string
#
# Permissions required:
# - Repository: Contents (Read & Write)
# - Repository: Metadata (Read)
# - Repository: Administration (Read & Write) - for creating repos
#
# After creating the app:
# 1. Copy the App ID
# 2. Generate a private key and download the .pem file
# 3. Copy the Client ID and generate a Client Secret
# =====================================================

# GitHub App ID (found on your app's settings page)
GITHUB_APP_ID=your_github_app_id_here

# GitHub App slug (the URL-friendly name in the app's URL)
GITHUB_APP_SLUG=your-app-slug

# GitHub App Client ID (from your GitHub App)
GITHUB_APP_CLIENT_ID=your_github_app_client_id_here

# GitHub App Client Secret (generate from your GitHub App settings)
GITHUB_APP_CLIENT_SECRET=your_github_app_client_secret_here

# GitHub App Private Key (copy entire contents of .pem file, replace newlines with \n)
# Example: -----BEGIN RSA PRIVATE KEY-----\nMIIE....\n-----END RSA PRIVATE KEY-----
GITHUB_PRIVATE_KEY=your_github_private_key_here

# GitHub Webhook Secret (generate a secure random string, set in app webhook settings)
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# GitHub App Redirect URI (after OAuth callback)
GITHUB_APP_REDIRECT_URI=https://your-domain.com/api/v1/app-github/oauth/callback

# =====================================================
# EMAIL CONFIGURATION (AWS SES)
# =====================================================
# Required for newsletter and contact form functionality
# Get your AWS credentials at: https://console.aws.amazon.com/iam/

# AWS Credentials for SES
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Email Settings
EMAIL_DEFAULT_FROM=noreply@wants.chat
SUPPORT_EMAIL=support@wants.chat

# Optional SMTP Configuration (fallback)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# =====================================================
# CLOUDFLARE R2 STORAGE CONFIGURATION
# =====================================================
# R2 is used for file uploads (images, documents, etc.)
# Get your credentials at: https://dash.cloudflare.com/r2
# =====================================================

CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_R2_BUCKET_NAME=your_bucket_name
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_here
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
CLOUDFLARE_R2_PUBLIC_URL=https://your-cdn-domain.com

# =====================================================
# RESEARCH & AUTONOMOUS TASKS CONFIGURATION
# =====================================================
# These APIs enable web research, content extraction, and autonomous task features

# Tavily Search API (for web search)
# Get your key at: https://tavily.com
# Pricing: 1000 free searches/month, then $0.01/search
TAVILY_API_KEY=your-tavily-api-key

# Exa Search API (for semantic search)
# Get your key at: https://exa.ai
# Pricing: 1000 free searches/month, then variable
EXA_API_KEY=

# Jina AI Reader (for content extraction)
# Get your key at: https://jina.ai
# Pricing: Free tier available, then usage-based
JINA_API_KEY=

# Firecrawl (for web scraping - optional)
# Get your key at: https://firecrawl.dev
# Pricing: 500 free credits, then $0.01/page
FIRECRAWL_API_KEY=

# BullMQ/Queue Configuration (uses existing Redis)
# QUEUE_CONCURRENCY: Number of concurrent jobs to process (default: 5)
# QUEUE_MAX_RETRIES: Max retry attempts for failed jobs (default: 3)
# QUEUE_RETRY_DELAY: Delay between retries in ms (default: 5000)
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY=5000

# Research Configuration
# RESEARCH_MAX_SOURCES: Maximum number of sources to gather (default: 20)
# RESEARCH_DEFAULT_DEPTH: Default research depth - basic, standard, or deep (default: standard)
# RESEARCH_TIMEOUT_SECONDS: Maximum time for research tasks in seconds (default: 300)
RESEARCH_MAX_SOURCES=20
RESEARCH_DEFAULT_DEPTH=standard
RESEARCH_TIMEOUT_SECONDS=300

# Browser Automation Configuration
# BROWSER_POOL_SIZE: Number of browser instances to maintain (default: 3)
# BROWSER_TIMEOUT_MS: Page load timeout in milliseconds (default: 30000)
# BROWSER_HEADLESS: Run browser in headless mode (default: true)
BROWSER_POOL_SIZE=3
BROWSER_TIMEOUT_MS=30000
BROWSER_HEADLESS=true
